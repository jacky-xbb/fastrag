# 环境变量与密钥
.env
.env.*
!.env.example

# 源数据 PDF（体积大，不入库）
pdf/

# Node / TypeScript
node_modules/
dist/
build/
*.tsbuildinfo
.mastra/

# Cloudflare Workers（本地状态 + 生成的运行时类型，CI 用 `wrangler types` 现生成）
.wrangler/
worker-configuration.d.ts

# libSQL / SQLite 本地库
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Python（OCR 对比脚本）
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# 日志与缓存
*.log
.cache/

# 编辑器 / 系统
.DS_Store
.idea/
.vscode/
.claude/

# OCR 脚本输出 + 入库 OCR 结果缓存（体积大、可重生）
ocr_out.md
ocr_cache/

# 入库进度 JSON（Node 入口 fsBucket 运行时生成，可重生）
ingest_status/

# Ralph 自主开发循环（开发工具，项目无关，可 `setup ralph` 一键重建）
ralph/
