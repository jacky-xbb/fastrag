{
  "name": "fastrag",
  "version": "0.1.0",
  "description": "防水卷材国标问答知识库",
  "private": true,
  "type": "module",
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:local": "DB_MODE=local tsx src/ingest.ts",
    "dev:api": "wrangler dev",
    "dev:api:local": "wrangler dev --var DB_MODE:local",
    "dev:db": "turso dev --db-file vector.db",
    "ui": "vite --config ui/vite.config.ts",
    "ui:build": "vite build --config ui/vite.config.ts",
    "dev": "concurrently -k -n api,ui -c blue,magenta \"npm:dev:api\" \"npm:ui\"",
    "dev:local": "concurrently -k -n db,api,ui -c green,blue,magenta \"npm:dev:db\" \"npm:dev:api:local\" \"npm:ui\"",
    "deploy": "npm run ui:build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "overrides": {
      "easy-day-js": "1.11.21"
    }
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@mastra/core": "1.42.0",
    "@mastra/libsql": "1.13.0",
    "@mastra/memory": "^1.20.3",
    "@mastra/rag": "2.2.1",
    "@openrouter/ai-sdk-provider": "2.9.1",
    "ai": "6.0.204",
    "dotenv": "^17.0.0",
    "unpdf": "1.6.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.208",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.0",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.101.0"
  }
}
